@model ProductUpdateViewModel
@{
    ViewData["Title"] = "Edit Product";
    var productId = ViewData["ProductId"];
}

<h1>Edit Product</h1>

<form asp-action="Edit" asp-route-id="@productId" method="post">
    @Html.AntiForgeryToken()
    
    <div class="mb-3">
        <label asp-for="ProductSku" class="form-label"></label>
        <input readonly asp-for="ProductSku" class="form-control-plaintext fw-bold">
    </div>
    
    <div class="mb-3">
        <label asp-for="UpdateRequest.Name" class="form-label"></label>
        <input asp-for="UpdateRequest.Name" class="form-control">
        <span asp-validation-for="UpdateRequest.Name" class="text-danger"></span>
    </div>
    
    <div class="mb-3">
        <label asp-for="UpdateRequest.Category" class="form-label"></label>
        <select asp-items="Model.CategoriesSelect" asp-for="UpdateRequest.Category" class="form-select"></select>
        <span asp-validation-for="UpdateRequest.Category" class="text-danger"></span>
    </div>
    
    <div class="mb-3">
        <label asp-for="UpdateRequest.Description" class="form-label"></label>
        <textarea asp-for="UpdateRequest.Description" class="form-control" rows="4"></textarea>
        <span asp-validation-for="UpdateRequest.Description" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="UpdateRequest.Price" class="form-label"></label>
        <input asp-for="UpdateRequest.Price" class="form-control" type="number" step="0.01">
        <span asp-validation-for="UpdateRequest.Price" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="UpdateRequest.ImageUrl" class="form-label"></label>
        <input asp-for="UpdateRequest.ImageUrl" class="form-control" type="url">
        <span asp-validation-for="UpdateRequest.ImageUrl" class="text-danger"></span>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>