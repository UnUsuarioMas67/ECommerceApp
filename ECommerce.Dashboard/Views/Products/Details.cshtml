@model ECommerce.Dashboard.DTOs.Product.ProductResponse
@{
    ViewData["Title"] = "Product Details";
}

<h1>Product Details</h1>

<div class="row">
    <div class="col-md-4">
        <img src="https://placehold.co/300" alt="@Model.Name" class="img-fluid">
    </div>
    <div class="col-md-8">
        <dl class="row">
            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.Name</dd>

            <dt class="col-sm-3">Sku</dt>
            <dd class="col-sm-9">@Model.Sku</dd>

            <dt class="col-sm-3">Category</dt>
            <dd class="col-sm-9">@Model.Category</dd>

            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">@Model.Description</dd>

            <dt class="col-sm-3">Price</dt>
            <dd class="col-sm-9">$ @Model.Price</dd>

            <dt class="col-sm-3">Stock</dt>
            <dd class="col-sm-9">
                @if (Model.Stock == 0)
                {
                    <span class="text-danger">@Model.Stock</span>
                }
                else
                {
                    @Model.Stock
                }
            </dd>
        </dl>

        <div class="mt-3">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
            <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure?')">Delete</button>
            </form>
        </div>

        <hr class="my-4">

        <h3>Restock</h3>
        <form asp-action="Restock" asp-route-id="@Model.Id" method="post" class="row g-3">
            @Html.AntiForgeryToken()
            <div class="col-auto">
                <input type="number" name="amount" class="form-control" placeholder="Amount" min="1" required>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-success">Restock</button>
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index">Back to List</a>
</div>