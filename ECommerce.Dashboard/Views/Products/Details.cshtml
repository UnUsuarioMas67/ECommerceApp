@model ECommerce.Dashboard.DTOs.Product.ProductResponse
@{
    ViewData["Title"] = "Product Details";
}

<h1 class="mb-3">@Model.Name</h1>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="row">

    <div class="col-md-4">
        @if (Model.ImageUrl != null)
        {
            var imgSrc = $"http://localhost:5113/images/products/{Model.ImageUrl}";
            <img src=@imgSrc alt="@Model.Name" class="img-fluid" onerror="this.src = 'https://placehold.co/300'">
        }
        else
        {
            <img src="https://placehold.co/300" alt="@Model.Name" class="img-fluid">
        }
    </div>
    <div class="col-md-8">
        <dl class="row">
            <dt class="col-sm-3">Sku</dt>
            <dd class="col-sm-9">@Model.Sku</dd>

            <dt class="col-sm-3">Category</dt>
            <dd class="col-sm-9">@Model.Category?.Name</dd>

            <dt class="col-sm-3">Price</dt>
            <dd class="col-sm-9">$ @Model.Price</dd>

            <dt class="col-sm-3">Stock</dt>
            <dd class="col-sm-9">
                @if (Model.Stock == 0)
                {
                    <span class="text-danger">@Model.Stock</span>
                }
                else
                {
                    @Model.Stock
                }
            </dd>
        </dl>

        <div class="mt-3">
            <a asp-action="Edit" asp-route-id="@Model.Id" title="Edit product" class="btn btn-primary">
                <i class="bi bi-pencil-fill"></i>
            </a>
            <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger" title="Delete product"
                        onclick="return confirm('Are you sure?')">
                    <i class="bi bi-trash-fill"></i>
                </button>
            </form>
        </div>

        <hr class="my-4">

        <h3>Restock</h3>
        <form asp-action="Restock" asp-route-id="@Model.Id" method="post" class="row g-3">
            @Html.AntiForgeryToken()
            <div class="col-auto">
                <input type="number" name="amount" class="form-control" placeholder="Amount" min="1" required>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-success" title="Add stock">
                    <i class="bi bi-plus-lg"></i>
                </button>
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index">Back to List</a>
</div>

<div class="mt-4">
    <h2>Description</h2>
    <p>@Model.Description</p>
</div>