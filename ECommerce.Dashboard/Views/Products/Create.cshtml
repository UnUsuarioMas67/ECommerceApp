@model ProductCreateViewModel
@{
    ViewData["Title"] = "Create Product";
}

<h1>Create Product</h1>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }
    
    <div class="mb-3">
        <label asp-for="CreateRequest.Sku" class="form-label"></label>
        <input asp-for="CreateRequest.Sku" class="form-control">
        <span asp-validation-for="CreateRequest.Sku" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="CreateRequest.Name" class="form-label"></label>
        <input asp-for="CreateRequest.Name" class="form-control">
        <span asp-validation-for="CreateRequest.Name" class="text-danger"></span>
    </div>
    
    <div class="mb-3">
        <label asp-for="CreateRequest.Category" class="form-label"></label>
        <select asp-items="Model.CategoriesSelect" asp-for="CreateRequest.Category" class="form-select"></select>
        <span asp-validation-for="CreateRequest.Category" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="CreateRequest.Description" class="form-label"></label>
        <textarea asp-for="CreateRequest.Description" class="form-control" rows="4"></textarea>
        <span asp-validation-for="CreateRequest.Description" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="CreateRequest.Price" class="form-label"></label>
        <input asp-for="CreateRequest.Price" class="form-control" type="number" step="0.01">
        <span asp-validation-for="CreateRequest.Price" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="CreateRequest.InitialStock" class="form-label"></label>
        <input asp-for="CreateRequest.InitialStock" class="form-control" type="number">
        <span asp-validation-for="CreateRequest.InitialStock" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="CreateRequest.ImageUrl" class="form-label"></label>
        <input asp-for="CreateRequest.ImageUrl" class="form-control" type="url">
        <span asp-validation-for="CreateRequest.ImageUrl" class="text-danger"></span>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Create</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>